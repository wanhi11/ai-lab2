@using SocOps.Models

<div class="flex flex-col min-h-full px-4 py-6">
    <!-- Header -->
    <header class="flex items-center justify-between mb-6">
        <button
            @onclick="OnReset"
            class="btn btn-soft text-sm px-3 py-2">
            ← Back
        </button>

        <div class="text-center">
            <p class="text-xs uppercase tracking-wide text-gray-400">Social Bingo</p>
            <h1 class="text-2xl font-bold text-white">Soc Ops</h1>
        </div>

        <div class="w-24"></div>
    </header>

    <!-- Instructions -->
    <div class="card p-4 mb-4">
        <p class="text-sm text-gray-700">
            Tap a square when you find someone who matches it.
        </p>
    </div>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="alert alert-success mb-4">
            <span class="text-lg">🎉</span>
            <span>BINGO! You got a line!</span>
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
