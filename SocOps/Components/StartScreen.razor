<div class="flex flex-col items-center justify-center min-h-full px-6 py-10">
    <div class="max-w-sm w-full space-y-6 text-center">
        <div class="relative">
            <div class="absolute -top-10 left-1/2 -translate-x-1/2 animate-float text-6xl">🎉</div>
            <h1 class="text-5xl font-bold text-white drop-shadow-lg">Soc Ops</h1>
        </div>

        <p class="text-lg text-gray-300">Social Bingo with a spark.</p>

        <div class="card p-6 space-y-4">
            <h2 class="font-semibold text-gray-900">How to play</h2>
            <ul class="text-left text-gray-700 text-sm space-y-2">
                <li>• Find people who match the questions</li>
                <li>• Tap a square when you find a match</li>
                <li>• Get 5 in a row to win!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="btn btn-primary w-full">
            Start game
            <span aria-hidden="true">→</span>
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
