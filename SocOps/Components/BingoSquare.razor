@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>

    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-secondary text-xs">✓</span>
        <span class="confetti"></span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "square select-none min-h-[60px] text-xs leading-tight";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "square-win"
                : "square-marked"
            : "";

        var freeSpaceClasses = Square.IsFreeSpace ? "square-free" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}".Trim();
    }
}
