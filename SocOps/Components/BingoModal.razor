<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="card-strong relative max-w-xs w-full p-6 text-center overflow-hidden">
        <div class="absolute -top-10 -left-10 text-5xl opacity-30 animate-float">✨</div>
        <div class="absolute -bottom-10 -right-10 text-6xl opacity-30 animate-float">🎉</div>

        <div class="text-6xl mb-4 animate-pop">🎊</div>
        <h2 class="text-3xl font-bold text-white mb-2">BINGO!</h2>
        <p class="text-gray-200 mb-6">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="btn btn-primary w-full">
            Keep playing
        </button>

        <div class="confetti" style="left: 20%; animation-delay: 0ms;"></div>
        <div class="confetti" style="left: 40%; animation-delay: 80ms; background: linear-gradient(135deg, var(--color-accent-2), var(--color-primary));"></div>
        <div class="confetti" style="left: 60%; animation-delay: 150ms; background: linear-gradient(135deg, var(--color-secondary), var(--color-primary-2));"></div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
